---
import Logo from "./Logo.astro";

const appUrl = "https://app.hypeterminal.com";
const repoUrl = "https://github.com/vipineth/hypeterminal";
const year = new Date().getFullYear();

const product = [
	{ label: "Open terminal", href: appUrl, icon: "terminal", external: true },
	{ label: "Features", href: "#features", icon: "sparkle" },
	{ label: "Blog", href: "/blog", icon: "article" },
	{ label: "FAQ", href: "#faq", icon: "question" },
];

const resources = [
	{ label: "GitHub", href: repoUrl, icon: "github", external: true },
	{ label: "Hyperliquid", href: "https://hyperliquid.xyz", icon: "link", external: true },
	{ label: "Twitter / X", href: "https://x.com/vipineth", icon: "x", external: true },
	{ label: "Contact", href: "mailto:hi@hypeterminal.com", icon: "mail" },
];

const iconSvg: Record<string, string> = {
	terminal: '<polyline points="56,80 96,128 56,176" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="20"/><line x1="120" y1="176" x2="200" y2="176" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="20"/>',
	sparkle: '<path d="M128,24V72" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16" fill="none"/><path d="M128,184v48" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16" fill="none"/><path d="M24,128H72" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16" fill="none"/><path d="M184,128h48" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16" fill="none"/><path d="M54.6,54.6,88.2,88.2" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16" fill="none"/><path d="M167.8,167.8l33.6,33.6" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16" fill="none"/><path d="M54.6,201.4,88.2,167.8" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16" fill="none"/><path d="M167.8,88.2l33.6-33.6" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16" fill="none"/>',
	article: '<rect x="40" y="40" width="176" height="176" rx="8" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"/><line x1="76" y1="96" x2="180" y2="96" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"/><line x1="76" y1="128" x2="180" y2="128" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"/><line x1="76" y1="160" x2="140" y2="160" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"/>',
	question: '<circle cx="128" cy="128" r="96" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"/><path d="M100,100a28,28,0,1,1,40,25.2c-8.4,4-12,11.5-12,18.8" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"/><circle cx="128" cy="180" r="10" fill="currentColor"/>',
	github: '<path d="M119.83,56A52,52,0,0,0,76,32a51.92,51.92,0,0,0-3.49,44.7A50,50,0,0,0,64,104v8a48,48,0,0,0,48,48h48a48,48,0,0,0,48-48v-8a50,50,0,0,0-8.51-27.3A51.92,51.92,0,0,0,196,32a52,52,0,0,0-43.83,24Z" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"/><path d="M104,232V192a32,32,0,0,1,32-32h0a32,32,0,0,1,32,32v40" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"/><path d="M104,208c-23,8-40,0-56-32" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"/>',
	x: '<line x1="48" y1="40" x2="208" y2="216" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="20"/><line x1="208" y1="40" x2="48" y2="216" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="20"/>',
	link: '<path d="M122.34,165.66l-12,12a32,32,0,0,1-45.25-45.25l40-40a32,32,0,0,1,45.26,0" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"/><path d="M133.66,90.34l12-12a32,32,0,0,1,45.25,45.25l-40,40a32,32,0,0,1-45.26,0" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"/>',
	mail: '<rect x="32" y="48" width="192" height="160" rx="8" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"/><polyline points="224,56 128,144 32,56" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"/>',
	arrowUpRight: '<line x1="64" y1="192" x2="192" y2="64" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="20"/><polyline points="88,64 192,64 192,168" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="20"/>',
	scale: '<rect x="32" y="48" width="192" height="160" rx="8" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"/><line x1="32" y1="96" x2="224" y2="96" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"/>',
};
---

<footer class="relative mt-auto border-t border-stroke-weaker">
	<div class="mx-auto w-full max-w-6xl px-5 sm:px-6 pt-12 md:pt-16 pb-8">
		<div class="flex flex-col md:flex-row md:items-center md:justify-between gap-5 rounded-xs border border-stroke-weak bg-fill-weaker px-5 md:px-7 py-5 md:py-6">
			<div>
				<div class="text-3xs uppercase tracking-uppercase text-fg-faint">Ready when you are</div>
				<p class="mt-1.5 text-sm md:text-base text-fg">
					Open the terminal and start trading on Hyperliquid.
				</p>
			</div>
			<a
				href={appUrl}
				class="press inline-flex h-10 items-center justify-center gap-2 rounded-xs bg-brand px-4 text-sm font-medium text-fg-inverse hover:opacity-90 transition-[opacity,transform] duration-200 self-start md:self-auto"
			>
				Open terminal
				<svg width="12" height="12" viewBox="0 0 256 256" aria-hidden="true" set:html={iconSvg.arrowUpRight} />
			</a>
		</div>

		<div class="mt-12 md:mt-16 grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-10">
			<div class="col-span-2">
				<Logo />
				<p class="mt-4 max-w-xs text-xs text-fg-muted leading-relaxed">
					The open-source terminal for Hyperliquid. Read it, fork it, run it yourself.
				</p>
				<a
					href={repoUrl}
					rel="noopener"
					class="mt-5 inline-flex items-center gap-2 rounded-xs border border-stroke-weak bg-surface px-3 py-1.5 text-2xs text-fg-muted hover:text-fg hover:border-stroke-strong transition-colors duration-200"
				>
					<svg width="14" height="14" viewBox="0 0 256 256" aria-hidden="true" set:html={iconSvg.github} />
					<span>Star on GitHub</span>
				</a>
			</div>

			<div>
				<div class="text-3xs uppercase tracking-uppercase text-fg-faint">Product</div>
				<ul class="mt-4 space-y-1 text-xs text-fg-muted">
					{product.map((item) => (
						<li>
							<a
								href={item.href}
								rel={item.external ? "noopener" : undefined}
								class="group inline-flex items-center gap-2 -ml-1.5 px-1.5 py-1 rounded-xs hover:text-fg hover:bg-fill-weaker transition-colors duration-150"
							>
								<span class="text-fg-faint group-hover:text-fg-muted transition-colors duration-150">
									<svg width="12" height="12" viewBox="0 0 256 256" aria-hidden="true" set:html={iconSvg[item.icon]} />
								</span>
								<span>{item.label}</span>
								{item.external && (
									<svg width="9" height="9" viewBox="0 0 256 256" aria-hidden="true" class="opacity-0 -translate-x-0.5 group-hover:opacity-60 group-hover:translate-x-0 transition" set:html={iconSvg.arrowUpRight} />
								)}
							</a>
						</li>
					))}
				</ul>
			</div>

			<div>
				<div class="text-3xs uppercase tracking-uppercase text-fg-faint">Resources</div>
				<ul class="mt-4 space-y-1 text-xs text-fg-muted">
					{resources.map((item) => (
						<li>
							<a
								href={item.href}
								rel={item.external ? "noopener" : undefined}
								class="group inline-flex items-center gap-2 -ml-1.5 px-1.5 py-1 rounded-xs hover:text-fg hover:bg-fill-weaker transition-colors duration-150"
							>
								<span class="text-fg-faint group-hover:text-fg-muted transition-colors duration-150">
									<svg width="12" height="12" viewBox="0 0 256 256" aria-hidden="true" set:html={iconSvg[item.icon]} />
								</span>
								<span>{item.label}</span>
								{item.external && (
									<svg width="9" height="9" viewBox="0 0 256 256" aria-hidden="true" class="opacity-0 -translate-x-0.5 group-hover:opacity-60 group-hover:translate-x-0 transition" set:html={iconSvg.arrowUpRight} />
								)}
							</a>
						</li>
					))}
				</ul>
			</div>
		</div>

		<div class="mt-10 md:mt-14 flex flex-col md:flex-row items-start md:items-center justify-between gap-4 border-t border-stroke-weaker pt-6">
			<p class="text-2xs text-fg-faint">
				© {year} Hypeterminal · Not financial advice. Trade at your own risk.
			</p>
			<div class="flex items-center gap-3 text-2xs text-fg-faint">
				<span class="inline-flex items-center gap-1.5">
					<svg width="11" height="11" viewBox="0 0 256 256" aria-hidden="true" set:html={iconSvg.scale} />
					<span class="uppercase tracking-uppercase">MIT licensed</span>
				</span>
				<span class="h-3 w-px bg-stroke-weaker"></span>
				<span class="inline-flex items-center gap-1.5">
					<span class="relative inline-flex">
						<span class="inline-block h-1.5 w-1.5 rounded-full bg-terminal"></span>
						<span class="absolute inset-0 inline-block h-1.5 w-1.5 rounded-full bg-terminal opacity-75 animate-ping"></span>
					</span>
					<span class="tabular uppercase tracking-uppercase">Live on mainnet</span>
				</span>
			</div>
		</div>
	</div>
</footer>
