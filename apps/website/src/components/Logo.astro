---
interface Props {
	withWordmark?: boolean;
	size?: "sm" | "md";
	href?: string | null;
}

const { withWordmark = true, size = "md", href = "/" } = Astro.props;
const iconSize = size === "sm" ? 22 : 26;
const Tag = href ? "a" : "span";
---

<Tag
	href={href ?? undefined}
	class:list={[
		"inline-flex items-center gap-2.5 text-fg",
		href && "hover:opacity-90 transition",
	]}
>
	<span
		class="inline-flex shrink-0 items-center justify-center rounded-4 border border-stroke-weak bg-terminal-soft"
		style={`width:${iconSize}px;height:${iconSize}px`}
		aria-hidden="true"
	>
		<svg
			width={iconSize - 10}
			height={iconSize - 10}
			viewBox="0 0 14 14"
			fill="none"
			stroke="var(--terminal)"
			stroke-width="2"
			stroke-linecap="round"
			stroke-linejoin="round"
		>
			<path d="M2 11l4-4-4-4" />
			<path d="M7 11h5" />
		</svg>
	</span>
	{withWordmark && (
		<span class="text-sm font-bold uppercase tracking-tight">
			<span class="text-brand">HYPE</span><span class="text-fg">TERMINAL</span>
		</span>
	)}
</Tag>
