---
const faqs = [
	{
		q: "What does it cost to use Hypeterminal?",
		a: "On every trade you pay Hyperliquid's standard maker/taker fees (paid to the protocol) plus a small 0.01% builder fee. That builder fee is what funds Hypeterminal — it pays for ongoing development, faster releases, new features, and keeping the terminal open-source and free to run. No subscription, no monthly fee, no charge for opening the app — just a tiny share of the trades you'd be making anyway.",
	},
	{
		q: "Do I need to sign up or KYC?",
		a: "No. Connect any EVM wallet — MetaMask, WalletConnect, Coinbase, and most browser wallets work — and start trading. No accounts, no email, no identity checks.",
	},
	{
		q: "Which order types are supported?",
		a: "Market, limit, stop-market, stop-limit, take-profit (market and limit), TWAP, and scaled orders. Limit orders support GTC, IOC, and ALO time-in-force, plus reduce-only.",
	},
	{
		q: "What's the max leverage?",
		a: "Up to 50× on perpetuals, configurable per position. You can switch between cross and isolated margin per market.",
	},
	{
		q: "Which markets are supported?",
		a: "All Hyperliquid perp markets, the spot order book, and builder-deployed DEXs. New markets appear automatically as they launch.",
	},
	{
		q: "Where does my data live?",
		a: "Nowhere on our side. The terminal talks directly to Hyperliquid's public WebSocket and signs orders locally with your wallet. Settings persist in your browser.",
	},
	{
		q: "Can I deposit or bridge funds?",
		a: "Yes. Deposit and withdraw via Arbitrum, with cross-chain bridging powered by LiFi across 19+ EVM networks.",
	},
	{
		q: "Does it work on mobile?",
		a: "Yes. The terminal has dedicated mobile views — not a shrunk desktop — with native gestures and panels tuned for trading on the go.",
	},
];
---

<section id="faq" class="border-b border-stroke-weaker">
	<div class="mx-auto w-full max-w-3xl px-5 sm:px-6 py-20 md:py-24">
		<div class="text-center mb-10 md:mb-12">
			<span class="text-3xs uppercase tracking-uppercase text-fg-faint">FAQ</span>
			<h2 class="mt-3 text-xl md:text-2xl font-medium tracking-display">Common questions.</h2>
		</div>

		<div class="divide-y divide-stroke-weaker border-y border-stroke-weaker">
			{faqs.map((f) => (
				<details class="group">
					<summary class="flex cursor-pointer items-center justify-between py-5 text-sm font-medium hover:text-fg-muted transition-colors duration-200 list-none gap-4">
						<span>{f.q}</span>
						<svg
							width="14"
							height="14"
							viewBox="0 0 12 12"
							fill="none"
							class="text-fg-faint group-open:rotate-45 transition-transform duration-200 shrink-0"
						>
							<path d="M6 1.5v9M1.5 6h9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
						</svg>
					</summary>
					<p class="pb-5 -mt-1 text-sm text-fg-muted leading-relaxed">{f.a}</p>
				</details>
			))}
		</div>
	</div>
</section>
