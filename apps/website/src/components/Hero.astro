---
const appUrl = "https://app.hypeterminal.com";
---

<section class="relative overflow-hidden border-b border-stroke-weaker">
	<div class="absolute inset-0 terminal-grid opacity-40 [mask-image:radial-gradient(ellipse_at_center,black,transparent_75%)]"></div>
	<div class="absolute inset-0 glow-radial"></div>

	<div class="relative mx-auto w-full max-w-6xl px-5 sm:px-6 pt-16 pb-20 md:pt-28 md:pb-28">
		<div class="stagger flex flex-col items-center text-center">
			<a
				href="#features"
				class="stagger-item press group inline-flex items-center gap-2 rounded-full border border-stroke-weak bg-fill-weaker px-3 py-1 text-2xs text-fg-muted hover:bg-fill-weak hover:border-stroke-weak/60 transition-colors duration-200"
			>
				<span class="relative inline-flex">
					<span class="inline-block h-1.5 w-1.5 rounded-full bg-terminal"></span>
					<span class="absolute inset-0 inline-block h-1.5 w-1.5 rounded-full bg-terminal opacity-75 animate-ping"></span>
				</span>
				<span class="uppercase tracking-uppercase">Open source · Live on mainnet</span>
				<svg width="10" height="10" viewBox="0 0 12 12" fill="none" aria-hidden="true" class="opacity-60 group-hover:translate-x-0.5 transition">
					<path d="M4.5 3l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
				</svg>
			</a>

			<h1 class="stagger-item mt-7 md:mt-8 max-w-3xl text-2xl md:text-4xl font-medium leading-[1.05] tracking-display">
				The open-source terminal<br />
				<span class="text-fg-subtle">for </span><span class="text-brand">Hyperliquid</span><span class="text-fg-subtle">.</span>
			</h1>

			<p class="stagger-item mt-5 md:mt-6 max-w-xl text-sm md:text-base text-fg-muted leading-relaxed">
				Read the client. Fork it. Run it yourself. Perp, spot, and builder markets in one workspace — pro charts, every order type, and 1–50× leverage on Hyperliquid's WebSocket.
			</p>

			<div class="stagger-item mt-8 md:mt-10 flex flex-col sm:flex-row items-stretch sm:items-center gap-3 w-full sm:w-auto">
				<a
					href={appUrl}
					class="press inline-flex h-11 items-center justify-center gap-2 rounded-xs bg-brand px-5 text-sm font-medium text-fg-inverse hover:opacity-90 transition-[opacity,transform] duration-200"
				>
					Open the terminal
					<svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
						<path d="M3 9l6-6M5 3h4v4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
					</svg>
				</a>
				<a
					href="#features"
					class="press inline-flex h-11 items-center justify-center gap-2 rounded-xs border border-stroke-weak px-5 text-sm text-fg-muted hover:text-fg hover:border-stroke-strong transition-colors duration-200"
				>
					See what's inside
				</a>
			</div>

			<p class="stagger-item mt-5 text-2xs text-fg-faint uppercase tracking-uppercase">
				Open source · Wallet-native · No signup
			</p>
		</div>

		<!-- Real app screenshots framed in a browser chrome. -->
		<div class="relative mx-auto mt-14 md:mt-20 max-w-5xl">
			<div class="absolute -inset-6 rounded-12 bg-fill-brand-weak blur-3xl opacity-50"></div>
			<div class="absolute -inset-2 rounded-12 ring-1 ring-stroke-weaker"></div>

			<div class="relative rounded-12 border border-stroke-weak bg-surface shadow-2xl overflow-hidden">
				<div class="flex items-center gap-1.5 border-b border-stroke-weaker px-3 md:px-4 py-2.5">
					<span class="h-2 w-2 md:h-2.5 md:w-2.5 rounded-full bg-fill-weak"></span>
					<span class="h-2 w-2 md:h-2.5 md:w-2.5 rounded-full bg-fill-weak"></span>
					<span class="h-2 w-2 md:h-2.5 md:w-2.5 rounded-full bg-fill-weak"></span>
					<div class="ml-3 md:ml-4 inline-flex items-center gap-1.5 rounded-full bg-fill-weaker px-2.5 py-0.5 text-2xs text-fg-faint tabular truncate">
						<svg width="9" height="9" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
							<rect x="2.5" y="3.5" width="7" height="6" rx="1.5"/>
							<path d="M4 3.5V2.5a2 2 0 0 1 4 0v1"/>
						</svg>
						<span>app.hypeterminal.com</span>
					</div>
				</div>

				<!-- Desktop screenshot (hidden on mobile) -->
				<img
					src="/app-desktop.jpeg"
					alt="HypeTerminal trading interface showing BTC-USDC chart, order book, and trade panel"
					class="hidden sm:block w-full h-auto bg-background"
					loading="eager"
					width="1600"
					height="1000"
				/>
				<!-- Mobile screenshot (only on small) -->
				<img
					src="/app-mobile.jpeg"
					alt="HypeTerminal mobile view showing BTC-USDC candle chart"
					class="sm:hidden w-full h-auto bg-background"
					loading="eager"
					width="390"
					height="844"
				/>
			</div>

			<!-- Floating "CONNECTED" status chip, anchored bottom-left of screenshot -->
			<div class="absolute -bottom-3 left-4 sm:left-6 hidden sm:inline-flex items-center gap-2 rounded-full border border-stroke-weak bg-surface px-3 py-1.5 text-2xs text-fg-muted shadow-lg">
				<span class="relative inline-flex">
					<span class="inline-block h-1.5 w-1.5 rounded-full bg-terminal"></span>
					<span class="absolute inset-0 inline-block h-1.5 w-1.5 rounded-full bg-terminal opacity-75 animate-ping"></span>
				</span>
				<span class="uppercase tracking-uppercase tabular">Connected · 12ms</span>
			</div>
		</div>
	</div>
</section>
