---
const stats = [
	{ value: "50×", label: "max leverage", icon: "gauge" },
	{ value: "100+", label: "perp markets", icon: "grid" },
	{ value: "Live", label: "WebSocket streams", icon: "bolt" },
];

const iconSvg: Record<string, string> = {
	gauge: '<path d="M40,176a88,88,0,0,1,176,0" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"/><line x1="128" y1="176" x2="168" y2="120" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"/>',
	grid: '<rect x="40" y="40" width="72" height="72" rx="8" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"/><rect x="144" y="40" width="72" height="72" rx="8" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"/><rect x="40" y="144" width="72" height="72" rx="8" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"/><rect x="144" y="144" width="72" height="72" rx="8" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"/>',
	bolt: '<polygon points="160,16 48,144 120,144 96,240 208,112 136,112 160,16" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"/>',
};
---

<section class="border-b border-stroke-weaker">
	<div class="mx-auto w-full max-w-5xl px-6 py-20 md:py-28">
		<div class="text-center">
			<span class="text-3xs uppercase tracking-uppercase text-fg-faint">Performance</span>
			<h2 class="mt-3 text-xl md:text-2xl font-medium tracking-display">Direct to Hyperliquid. No middlemen.</h2>
			<p class="mt-4 mx-auto max-w-md text-sm text-fg-muted leading-relaxed">
				No backend, no servers, no relayers. The terminal talks straight to Hyperliquid's WebSocket and signs locally with your wallet.
			</p>
		</div>

		<div class="mt-12 md:mt-14 grid grid-cols-1 md:grid-cols-3 gap-px bg-stroke-weaker rounded-xs overflow-hidden border border-stroke-weak">
			{stats.map((s) => (
				<div class="bg-surface p-6 md:p-8 text-center">
					<div class="mx-auto mb-3 inline-flex h-9 w-9 items-center justify-center rounded-xs bg-fill-weaker text-fg-muted">
						<svg width="16" height="16" viewBox="0 0 256 256" aria-hidden="true" set:html={iconSvg[s.icon]} />
					</div>
					<div class="text-2xl md:text-3xl font-medium tabular tracking-tight">{s.value}</div>
					<div class="mt-1 text-2xs text-fg-faint uppercase tracking-uppercase">{s.label}</div>
				</div>
			))}
		</div>
	</div>
</section>
