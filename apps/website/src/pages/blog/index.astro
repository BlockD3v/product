---
import { getCollection } from "astro:content";
import Base from "@/layouts/Base.astro";
import Nav from "@/components/Nav.astro";
import Footer from "@/components/Footer.astro";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
	(a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const formatter = new Intl.DateTimeFormat("en-US", {
	year: "numeric",
	month: "short",
	day: "numeric",
});
---

<Base
	title="Blog — HypeTerminal"
	description="Notes from building an open-source trading terminal for Hyperliquid."
>
	<Nav />
	<main>
		<section class="border-b border-stroke-weaker">
			<div class="mx-auto w-full max-w-3xl px-5 sm:px-6 pt-16 pb-12 md:pt-24 md:pb-16">
				<span class="text-3xs uppercase tracking-uppercase text-fg-faint">Blog</span>
				<h1 class="mt-3 text-2xl md:text-3xl font-medium tracking-display leading-[1.05]">
					Notes from the terminal.
				</h1>
				<p class="mt-4 max-w-xl text-sm md:text-base text-fg-muted leading-relaxed">
					Architecture, signing flows, self-hosting, weekly changelog — written in the open.
				</p>
			</div>
		</section>

		<section>
			<div class="mx-auto w-full max-w-3xl px-5 sm:px-6 py-12 md:py-16">
				{posts.length === 0 ? (
					<p class="text-sm text-fg-muted">No posts yet — check back soon.</p>
				) : (
					<ul class="divide-y divide-stroke-weaker border-y border-stroke-weaker">
						{posts.map((post) => (
							<li>
								<a
									href={`/blog/${post.id.replace(/\.md$/, "")}`}
									class="group flex flex-col gap-2 py-6 md:flex-row md:items-baseline md:justify-between md:gap-8"
								>
									<div class="flex-1">
										<h2 class="text-base md:text-lg font-medium leading-snug group-hover:text-fg-muted transition-colors duration-200">
											{post.data.title}
										</h2>
										<p class="mt-1.5 text-sm text-fg-muted leading-relaxed">
											{post.data.description}
										</p>
									</div>
									<time
										datetime={post.data.date.toISOString()}
										class="text-2xs uppercase tracking-uppercase text-fg-faint tabular shrink-0"
									>
										{formatter.format(post.data.date)}
									</time>
								</a>
							</li>
						))}
					</ul>
				)}
			</div>
		</section>
	</main>
	<Footer />
</Base>
