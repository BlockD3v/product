---
import "../styles/global.css";
import { SEO_DEFAULTS } from "@/config/seo";
import { resolveSeo, type PageSeo } from "@/lib/seo";

interface Props extends PageSeo {
	jsonLd?: unknown | unknown[];
}

const { jsonLd, ...seoOptions } = Astro.props;

const seo = resolveSeo({
	path: Astro.url.pathname,
	...seoOptions,
});

const schemas = jsonLd === undefined ? [] : Array.isArray(jsonLd) ? jsonLd : [jsonLd];
---

<!doctype html>
<html lang="en" class="dark">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
		<meta name="theme-color" content={SEO_DEFAULTS.themeColor} />
		<meta name="color-scheme" content="dark light" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="apple-touch-icon" href="/favicon.svg" />

		<title>{seo.title}</title>
		<meta name="description" content={seo.description} />
		<meta name="keywords" content={seo.keywords} />
		<meta name="author" content={SEO_DEFAULTS.siteName} />
		<meta
			name="robots"
			content={seo.noIndex ? "noindex, nofollow" : "index, follow, max-image-preview:large, max-snippet:-1"}
		/>

		<meta property="og:type" content={seo.ogType} />
		<meta property="og:site_name" content={SEO_DEFAULTS.siteName} />
		<meta property="og:title" content={seo.title} />
		<meta property="og:description" content={seo.description} />
		<meta property="og:url" content={seo.canonical} />
		<meta property="og:locale" content={SEO_DEFAULTS.locale} />
		<meta property="og:image" content={seo.ogImage} />
		<meta property="og:image:alt" content={seo.ogImageAlt} />
		<meta property="og:image:width" content={String(SEO_DEFAULTS.ogImageWidth)} />
		<meta property="og:image:height" content={String(SEO_DEFAULTS.ogImageHeight)} />

		{seo.ogType === "article" && seo.publishedTime && (
			<meta property="article:published_time" content={seo.publishedTime} />
		)}
		{seo.ogType === "article" && seo.modifiedTime && (
			<meta property="article:modified_time" content={seo.modifiedTime} />
		)}
		{seo.ogType === "article" && seo.author && <meta property="article:author" content={seo.author} />}

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:site" content={SEO_DEFAULTS.twitterHandle} />
		<meta name="twitter:creator" content={SEO_DEFAULTS.twitterHandle} />
		<meta name="twitter:title" content={seo.title} />
		<meta name="twitter:description" content={seo.description} />
		<meta name="twitter:image" content={seo.ogImage} />
		<meta name="twitter:image:alt" content={seo.ogImageAlt} />

		<link rel="canonical" href={seo.canonical} />
		<link rel="sitemap" href="/sitemap-index.xml" />

		<link rel="preconnect" href="https://app.hypeterminal.com" />
		<link rel="dns-prefetch" href="https://app.hypeterminal.com" />

		{schemas.map((schema) => (
			<script type="application/ld+json" set:html={JSON.stringify(schema)} />
		))}
	</head>
	<body class="flex min-h-screen flex-col bg-background text-fg antialiased">
		<slot />
	</body>
</html>
