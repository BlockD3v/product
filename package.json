{
	"name": "hypeterminal",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "pnpm --filter @hypeterminal/terminal dev",
		"build": "pnpm --filter @hypeterminal/terminal build",
		"serve": "pnpm --filter @hypeterminal/terminal serve",
		"test": "pnpm --filter @hypeterminal/terminal test",
		"diagnostics:browser": "node scripts/browser-diagnostics.js",
		"validate:mobile-device": "node scripts/validate-mobile-phone-access-device-validation.js",
		"test:mobile-device-validator": "node --test scripts/validate-mobile-phone-access-device-validation.test.js",
		"template:mobile-device": "node scripts/validate-mobile-phone-access-device-validation.js --print-template",
		"init:mobile-device": "node scripts/validate-mobile-phone-access-device-validation.js --init-missing",
		"format": "biome format",
		"lint": "biome lint",
		"check": "biome check",
		"fix": "biome check --write",
		"i18n:extract": "pnpm --filter @hypeterminal/terminal i18n:extract",
		"i18n:compile": "pnpm --filter @hypeterminal/terminal i18n:compile",
		"prepare": "lefthook install"
	},
	"devDependencies": {
		"@ai-hero/sandcastle": "0.5.6",
		"@biomejs/biome": "2.2.4",
		"@commitlint/cli": "20.3.1",
		"@commitlint/config-conventional": "20.3.1",
		"lefthook": "1.11.0",
		"typescript": "5.7.2"
	},
	"pnpm": {
		"overrides": {
			"@noble/hashes": "1.8.0"
		}
	}
}
